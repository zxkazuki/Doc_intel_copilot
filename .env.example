# AWS Configuration
AWS_REGION=us-east-1

# S3 Configuration
S3_BUCKET_NAME=doc-intel-copilot-documents
S3_PRESIGNED_URL_EXPIRY=3600

# DynamoDB Table Names
DYNAMODB_DOCUMENTS_TABLE=Documents
DYNAMODB_EXTRACTIONS_TABLE=Extractions
DYNAMODB_INSIGHTS_TABLE=Insights
DYNAMODB_REVIEWS_TABLE=HumanReviews

# Bedrock Configuration
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# File Upload Limits
MAX_FILE_SIZE_MB=20
ALLOWED_FORMATS=["pdf","png","jpg","jpeg"]

# Timeout Configuration (seconds)
CLASSIFICATION_TIMEOUT=30
EXTRACTION_TIMEOUT=30
INSIGHTS_TIMEOUT=30
