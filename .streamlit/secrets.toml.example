# Streamlit Community Cloud — Secrets
# Cole este conteúdo (com os valores reais) em:
# App settings > Secrets, no painel do Streamlit Cloud.
# As chaves abaixo são expostas como variáveis de ambiente para a aplicação.

AWS_ACCESS_KEY_ID = "COLE_O_ACCESS_KEY_ID_AQUI"
AWS_SECRET_ACCESS_KEY = "COLE_O_SECRET_ACCESS_KEY_AQUI"
AWS_DEFAULT_REGION = "us-east-1"
AWS_REGION = "us-east-1"

S3_BUCKET_NAME = "doc-intel-copilot-docs-608040300344"
DYNAMODB_DOCUMENTS_TABLE = "doc-intel-documents"
DYNAMODB_EXTRACTIONS_TABLE = "doc-intel-extractions"
DYNAMODB_INSIGHTS_TABLE = "doc-intel-insights"
DYNAMODB_REVIEWS_TABLE = "doc-intel-reviews"
BEDROCK_MODEL_ID = "us.anthropic.claude-sonnet-4-6"
MAX_FILE_SIZE_MB = "20"
